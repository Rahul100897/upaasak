{%- comment -%}
  About Us Story Section for Lesure
{%- endcomment -%}

<div class="lesure-about-wrapper">
  <div class="lesure-about-story">
    {%- for block in section.blocks -%}
      <div class="story-row" {{ block.shopify_attributes }}>
        {%- if block.settings.reverse -%}
          <div class="story-txt {% if block.settings.bg_off %}bg{% endif %}">
            <span class="slabel">{{ block.settings.label }}</span>
            <h2>{{ block.settings.title }}</h2>
            <div class="story-content">
              {{ block.settings.content }}
            </div>
            {%- if block.settings.proof_text != blank -%}
              <div class="proofbox"><p>{{ block.settings.proof_text }}</p></div>
            {%- endif -%}
          </div>
          <div class="story-img">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | img_url: '1000x' }}" alt="{{ block.settings.title | escape }}" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;">
            {%- else -%}
              <div class="story-img-ph">[Image: {{ block.settings.title }}]</div>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="story-img">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | img_url: '1000x' }}" alt="{{ block.settings.title | escape }}" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;">
            {%- else -%}
              <div class="story-img-ph">[Image: {{ block.settings.title }}]</div>
            {%- endif -%}
          </div>
          <div class="story-txt {% if block.settings.bg_off %}bg{% endif %}">
            <span class="slabel">{{ block.settings.label }}</span>
            <h2>{{ block.settings.title }}</h2>
            <div class="story-content">
              {{ block.settings.content }}
            </div>
            {%- if block.settings.proof_text != blank -%}
              <div class="proofbox"><p>{{ block.settings.proof_text }}</p></div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Lesure About Story",
  "settings": [],
  "blocks": [
    {
      "type": "story_row",
      "name": "Story Row",
      "settings": [
        { "type": "checkbox", "id": "reverse", "label": "Reverse Layout", "default": false },
        { "type": "checkbox", "id": "bg_off", "label": "Off-white Background", "default": false },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "content", "label": "Content" },
        { "type": "text", "id": "proof_text", "label": "Proof Box Text" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    { "name": "Lesure About Story" }
  ]
}
{% endschema %}
