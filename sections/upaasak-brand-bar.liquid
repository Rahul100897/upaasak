{% render 'upaasak-design-system' %}

<section class="u-section u-brandbar" data-section-id="{{ section.id }}">
  <div class="u-brandbar__in">
    <a class="u-lockup" href="{{ routes.root_url }}">
      {% if section.settings.logo %}
        <img src="{{ section.settings.logo | image_url: width: 120 }}" alt="{{ shop.name | escape }}" width="48" height="48" style="height:46px;width:auto;border-radius:10px">
      {% else %}
        <span class="u-lockup__mark">{{ section.settings.logo_letter | default: 'ॐ' }}</span>
      {% endif %}
      <span>
        <span class="u-lockup__name">{{ section.settings.brand_name }}</span>
        <span class="u-lockup__slogan">{{ section.settings.slogan }}</span>
      </span>
    </a>

    <div class="u-search-wrap" data-psearch>
      <form action="{{ routes.search_url }}" method="get" class="u-search" role="search" autocomplete="off">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5" stroke-linecap="round"/></svg>
        <input type="search" name="q" placeholder="{{ section.settings.search_placeholder }}" autocomplete="off" data-psearch-input aria-label="Search">
        <button type="button" class="u-search-clear" data-psearch-clear aria-label="Clear search" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
        </button>
      </form>
      <div class="u-psearch" data-psearch-results role="listbox" aria-label="Search suggestions"></div>
    </div>

    <div class="u-brandbar__tools">
      <button type="button" class="u-icon-btn u-search-toggle" data-search-toggle aria-label="Search" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5" stroke-linecap="round"/></svg>
      </button>
      <a class="u-icon-btn" href="{{ routes.account_url | default: '/account' }}" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="8" r="4"/><path d="M5 20c0-3.9 3.1-7 7-7s7 3.1 7 7" stroke-linecap="round"/></svg>
      </a>
      <a class="u-icon-btn" href="{{ routes.cart_url }}" aria-label="Cart" data-cart-toggle>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l2.2 11.2a1.5 1.5 0 0 0 1.5 1.2h8.3a1.5 1.5 0 0 0 1.5-1.2L21 8H6"/></svg>
        <span class="u-badge" data-cart-badge>{{ cart.item_count | default: 0 }}</span>
      </a>
      <button type="button" class="u-icon-btn u-burger" data-burger aria-label="Open menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Brand Bar",
  "enabled_on": {
    "groups": [
      "header"
    ]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (optional — overrides letter mark)"
    },
    {
      "type": "text",
      "id": "logo_letter",
      "label": "Logo mark letter",
      "default": "ॐ"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "UPAASAK"
    },
    {
      "type": "text",
      "id": "slogan",
      "label": "Slogan",
      "default": "Authentic Spiritual Essentials"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search for Rudraksha, Mala, Bracelets…"
    }
  ],
  "presets": [
    {
      "name": "Upaasak Brand Bar"
    }
  ]
}
{% endschema %}
