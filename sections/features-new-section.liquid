{{ 'features-section.css' | asset_url | stylesheet_tag }}

<section class="feature-section" id="feature-section-{{ section.id }}">

  <!-- LEFT: Image -->
  <div class="feature-image-wrap">
    {% if section.settings.image != blank %}
      {% assign img_url = section.settings.image | image_url: width: 900 %}
      {% assign img_alt = section.settings.image.alt | escape %}
      <img src="{{ img_url }}" alt="{{ img_alt }}" class="feature-img" loading="lazy" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
    {% else %}
      <div class="img-placeholder">
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {% endif %}
  </div>

  <!-- RIGHT: Content -->
  <div class="feature-content">

    {% if section.settings.heading != blank %}
      <h2 class="feature-heading">
        {{ section.settings.heading }}
        {% if section.settings.heading_highlight != blank %}
          <span class="highlight">{{ section.settings.heading_highlight }}</span>
        {% endif %}
      </h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="feature-card">
        {% for block in section.blocks %}
          {% if block.type == 'feature_item' %}
            <div class="feature-item" {{ block.shopify_attributes }}>
              <div class="feature-item-header">

                {% if block.settings.icon != blank %}
                  <div class="feature-icon feature-icon--image">
                    {% assign icon_url = block.settings.icon | image_url: width: 72 %}
                    <img src="{{ icon_url }}" alt="{{ block.settings.title }}" class="feature-icon-img" loading="lazy" width="32" height="32">
                  </div>
                {% else %}
                  <div class="feature-icon feature-icon--svg">
                    {% case block.settings.icon_type %}
                      {% when 'clamp' %}
                        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <rect x="3" y="4" width="16" height="12" rx="2" stroke="#333" stroke-width="1.6" fill="none"/>
                          <rect x="5" y="6" width="12" height="8" rx="1" stroke="#333" stroke-width="1.3" fill="none"/>
                          <line x1="19" y1="10" x2="28" y2="10" stroke="#333" stroke-width="1.6" stroke-linecap="round"/>
                          <line x1="25" y1="7" x2="25" y2="24" stroke="#333" stroke-width="1.6" stroke-linecap="round"/>
                          <line x1="22" y1="24" x2="28" y2="24" stroke="#333" stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                      {% when 'fold' %}
                        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <rect x="4" y="14" width="14" height="10" rx="1.5" stroke="#333" stroke-width="1.6" fill="none"/>
                          <rect x="4" y="4" width="10" height="10" rx="1.5" stroke="#333" stroke-width="1.6" fill="none"/>
                          <path d="M14 9 L18 9 L18 14" stroke="#333" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                          <text x="6" y="22" font-size="6" fill="#333" font-family="sans-serif" font-weight="600">90°</text>
                        </svg>
                      {% when 'wash' %}
                        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <rect x="3" y="3" width="26" height="26" rx="3" stroke="#333" stroke-width="1.6" fill="none"/>
                          <line x1="3" y1="10" x2="29" y2="10" stroke="#333" stroke-width="1.4"/>
                          <circle cx="16" cy="20" r="6" stroke="#333" stroke-width="1.6" fill="none"/>
                          <circle cx="16" cy="20" r="3" stroke="#333" stroke-width="1.3" fill="none" stroke-dasharray="3 2"/>
                          <circle cx="7" cy="6.5" r="1.2" fill="#333"/>
                          <circle cx="11" cy="6.5" r="1.2" fill="#333"/>
                        </svg>
                      {% when 'nest' %}
                        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M5 18 C5 12 27 12 27 18 C27 24 5 24 5 18 Z" stroke="#333" stroke-width="1.6" fill="none"/>
                          <path d="M9 18 C9 15 23 15 23 18" stroke="#333" stroke-width="1.3" stroke-linecap="round" fill="none"/>
                          <path d="M7 24 C7 27 25 27 25 24" stroke="#333" stroke-width="1.4" stroke-linecap="round" fill="none"/>
                          <ellipse cx="12" cy="10" rx="2" ry="1.5" stroke="#333" stroke-width="1.2" fill="none"/>
                          <ellipse cx="20" cy="9" rx="2" ry="1.5" stroke="#333" stroke-width="1.2" fill="none"/>
                          <ellipse cx="16" cy="8" rx="1.5" ry="1.2" stroke="#333" stroke-width="1.2" fill="none"/>
                        </svg>
                      {% when 'star' %}
                        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M16 4l2.9 8.9H28l-7.5 5.5 2.9 8.9L16 22l-7.4 5.3 2.9-8.9L4 12.9h9.1z" stroke="#333" stroke-width="1.6" fill="none" stroke-linejoin="round"/>
                        </svg>
                      {% when 'shield' %}
                        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M16 3 L28 8 L28 17 C28 23 22 28 16 30 C10 28 4 23 4 17 L4 8 Z" stroke="#333" stroke-width="1.6" fill="none" stroke-linejoin="round"/>
                          <path d="M11 16l3.5 3.5L21 12" stroke="#333" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% when 'leaf' %}
                        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M6 26 C6 26 8 14 16 10 C24 6 28 8 28 8 C28 8 26 18 18 22 C14 24 10 24 6 26Z" stroke="#333" stroke-width="1.6" fill="none" stroke-linejoin="round"/>
                          <line x1="6" y1="26" x2="18" y2="14" stroke="#333" stroke-width="1.4" stroke-linecap="round"/>
                        </svg>
                      {% else %}
                        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="16" cy="16" r="12" stroke="#333" stroke-width="1.6" fill="none"/>
                          <path d="M11 16l3.5 3.5L21 12" stroke="#333" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    {% endcase %}
                  </div>
                {% endif %}

                {% if block.settings.title != blank %}
                  <span class="feature-title">{{ block.settings.title }}</span>
                {% endif %}
              </div>

              {% if block.settings.description != blank %}
                <p class="feature-desc">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

  </div><!-- /.feature-content -->
</section>

<style>
  #feature-section-{{ section.id }} .feature-heading .highlight {
    color: {{ section.settings.highlight_color }};
  }
  #feature-section-{{ section.id }} .feature-card {
    background: {{ section.settings.card_bg_color }};
  }
  #feature-section-{{ section.id }} {
    padding: {{ section.settings.section_padding_vertical }}px {{ section.settings.section_padding_horizontal }}px;
  }
</style>

{% schema %}
{
  "name": "Feature Section",
  "tag": "section",
  "class": "feature-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_vertical",
      "label": "Vertical Padding (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Horizontal Padding (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (Normal Text)",
      "default": "Built for cats who"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight Text",
      "default": "refuse to be ignored",
      "info": "This part appears in the accent color below"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Color",
      "default": "#c9a96e"
    },
    {
      "type": "header",
      "content": "Feature Card"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#f8f6f2"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description",
          "default": "Describe this feature in one or two short sentences."
        },
        {
          "type": "header",
          "content": "Icon"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Built-in Icon",
          "info": "Used when no custom icon image is uploaded",
          "options": [
            { "value": "clamp",  "label": "Clamp" },
            { "value": "fold",   "label": "Foldable / 90°" },
            { "value": "wash",   "label": "Machine Washable" },
            { "value": "nest",   "label": "Nest / Bowl" },
            { "value": "star",   "label": "Star" },
            { "value": "shield", "label": "Shield / Protection" },
            { "value": "leaf",   "label": "Leaf / Eco" },
            { "value": "check",  "label": "Checkmark" }
          ],
          "default": "check"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom Icon Image",
          "info": "Upload a custom icon (PNG/SVG). This overrides the built-in icon above."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Section",
      "blocks": [
        {
          "type": "feature_item",
          "settings": {
            "title": "No-Drill Clamp",
            "description": "Fits desk edges from 0.8\" to 2.7\" thick. Steel clamp holds up to 40 lbs with zero wall damage.",
            "icon_type": "clamp"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "title": "90° Foldable",
            "description": "Fold it flat under the desk when not in use. Takes up zero floor space. Back up in seconds.",
            "icon_type": "fold"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "title": "Machine Washable",
            "description": "The plush cover pops off easily. Toss it in the wash and have it fresh again in no time.",
            "icon_type": "wash"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "title": "Ultra-Plush Nest",
            "description": "15.7\" diameter, deep-bowl design mimics your cat's natural urge to curl up and feel secure.",
            "icon_type": "nest"
          }
        }
      ]
    }
  ]
}
{% endschema %}
