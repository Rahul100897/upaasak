{% render 'upaasak-design-system' %}

<section class="u-section u-why" data-section-id="{{ section.id }}">
  <div class="u-wrap">
    <div class="u-section-head is-centered">
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal>{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:60ms">{{ section.settings.heading }}</h2>
    </div>

    <div class="u-why__banner" data-reveal="zoom">
      {% if section.settings.banner %}
        <img src="{{ section.settings.banner | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" width="2000" height="750" loading="lazy">
      {% else %}
        <div class="u-why__banner-ph">{{ section.settings.banner_placeholder }}</div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="u-why__usps">
        {% for block in section.blocks %}
          <div class="u-why__usp" data-reveal style="--d:{{ forloop.index0 | times: 90 }}ms" {{ block.shopify_attributes }}>
            <div class="u-why__usp-ico">{% render 'upaasak-icon', icon: block.settings.icon %}</div>
            <h4>{{ block.settings.title }}</h4>
            <p>{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Why Choose Us",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Choose Us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tradition Behind Every Bead" },
    { "type": "image_picker", "id": "banner", "label": "Journey banner image (wide)" },
    { "type": "text", "id": "banner_placeholder", "label": "Placeholder text", "default": "Sourced · Verified · Energized · Delivered" }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "certificate",
          "options": [
            { "value": "certificate", "label": "Certificate" }, { "value": "leaf", "label": "Leaf" },
            { "value": "om", "label": "Om" }, { "value": "shield", "label": "Shield" },
            { "value": "hand", "label": "Hand" }, { "value": "lotus", "label": "Lotus" },
            { "value": "gem", "label": "Gem" }, { "value": "sparkle", "label": "Sparkle" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Lab Certified" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Every bead verified for authenticity and origin." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upaasak Why Choose Us",
      "blocks": [
        { "type": "usp", "settings": { "icon": "leaf", "title": "Ethically Sourced", "text": "Hand-gathered from trusted growers in Nepal & Indonesia." } },
        { "type": "usp", "settings": { "icon": "certificate", "title": "Lab Certified", "text": "Independently tested for mukhi, origin and purity." } },
        { "type": "usp", "settings": { "icon": "om", "title": "Energized", "text": "Abhimantrit with Vedic mantras before dispatch." } },
        { "type": "usp", "settings": { "icon": "shield", "title": "100% Trusted", "text": "25,000+ devotees & a 7-day money-back promise." } }
      ]
    }
  ]
}
{% endschema %}
