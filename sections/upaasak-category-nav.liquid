{% render 'upaasak-design-system' %}

<section class="u-section u-catnav" data-section-id="{{ section.id }}" data-catnav>
  <span class="u-catnav__overlay" data-catnav-close></span>
  <nav class="u-catnav__in" aria-label="Categories">
    <div class="u-catnav__head">
      <span class="u-catnav__head-title">Menu</span>
      <button type="button" class="u-catnav__close" data-catnav-close aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
    </div>
    {% for block in section.blocks %}
      <a class="u-catnav__item" href="{{ block.settings.link | default: '#' }}" data-catnav-close {{ block.shopify_attributes }}>
        {% if block.settings.image %}
          <img class="u-catnav__ico" src="{{ block.settings.image | image_url: width: 44 }}" alt="" width="22" height="22">
        {% else %}
          {% render 'upaasak-icon', icon: block.settings.icon %}
        {% endif %}
        {{ block.settings.label }}
      </a>
    {% endfor %}
  </nav>
</section>

{% schema %}
{
  "name": "Upaasak Category Nav",
  "enabled_on": {
    "groups": [
      "header"
    ]
  },
  "settings": [],
  "blocks": [
    {
      "type": "cat",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop All"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom icon image (optional)"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "bead",
          "options": [
            {
              "value": "bead",
              "label": "Bead"
            },
            {
              "value": "lotus",
              "label": "Lotus"
            },
            {
              "value": "om",
              "label": "Om"
            },
            {
              "value": "gem",
              "label": "Gem / Stones"
            },
            {
              "value": "mantra",
              "label": "Mala"
            },
            {
              "value": "leaf",
              "label": "Leaf"
            },
            {
              "value": "deity",
              "label": "Idol / Deity"
            },
            {
              "value": "gift",
              "label": "Gifting"
            },
            {
              "value": "sparkle",
              "label": "Sparkle"
            },
            {
              "value": "certificate",
              "label": "Certificate / PDF"
            },
            {
              "value": "shield",
              "label": "Shield"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upaasak Category Nav",
      "blocks": [
        {
          "type": "cat",
          "settings": {
            "label": "Shop All",
            "icon": "sparkle"
          }
        },
        {
          "type": "cat",
          "settings": {
            "label": "Karungali",
            "icon": "bead"
          }
        },
        {
          "type": "cat",
