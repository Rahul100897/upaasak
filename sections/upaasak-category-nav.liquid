            "icon": "gem"
          }
        },
        {
          "type": "cat",
          "settings": {
            "label": "Mala",
            "icon": "mantra"
          }
        },
        {
          "type": "cat",
          "settings": {
            "label": "Stones",
            "icon": "gem"
          }
        },
        {
          "type": "cat",
          "settings": {
            "label": "Idols",
            "icon": "deity"
          }
        },
        {
          "type": "cat",
          "settings": {
            "label": "Gifting",
            "icon": "gift"
          }
        },
        {
