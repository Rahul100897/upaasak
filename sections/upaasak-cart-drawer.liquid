{% render 'upaasak-design-system' %}

{%- liquid
  assign threshold = section.settings.free_ship_threshold | times: 100
  assign free_ship = false
  if threshold > 0 and cart.total_price >= threshold
    assign free_ship = true
  endif
  assign flat_shipping = section.settings.flat_shipping_rate | default: 0 | times: 100

  comment
    Total savings = per-line compare-at savings + any cart-level discounts
  endcomment
  assign savings = 0
  for line in cart.items
    if line.variant.compare_at_price > line.variant.price
      assign diff = line.variant.compare_at_price | minus: line.variant.price | times: line.quantity
      assign savings = savings | plus: diff
    endif
  endfor
  assign savings = savings | plus: cart.total_discount

  comment
    Payment Summary breakdown: MRP total, item-level discount, sub total
  endcomment
  assign mrp_total = 0
  assign item_discount = 0
  for line in cart.items
    assign lc = line.variant.compare_at_price
    assign lp = line.variant.price
    assign lq = line.quantity
    if lc > lp
      assign line_mrp = lc | times: lq
      assign line_disc = lc | minus: lp | times: lq
    else
      assign line_mrp = lp | times: lq
      assign line_disc = 0
    endif
    assign mrp_total = mrp_total | plus: line_mrp
    assign item_discount = item_discount | plus: line_disc
  endfor
  assign sub_total = mrp_total | minus: item_discount

  assign ddays = section.settings.delivery_days | default: 7
  assign dsecs = ddays | times: 86400
  assign eta = 'now' | date: '%s' | plus: dsecs | date: '%b %d'
-%}

<div class="u-cart" data-cart-drawer aria-hidden="true">
  <div class="u-cart__overlay" data-cart-close></div>
  <aside class="u-cart__panel" role="dialog" aria-modal="true" aria-label="Shopping cart">
    <div id="u-cart-contents" data-cart-count="{{ cart.item_count }}">

      <header class="u-cart__head">
        <h2 class="u-cart__title">{{ section.settings.title }} <span class="u-cart__num">{{ cart.item_count }}</span></h2>
        <button type="button" class="u-cart__x" data-cart-close aria-label="Close cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
        </button>
      </header>

      {% if cart.item_count > 0 %}
        <div class="u-cart__scroll">
          {% if section.settings.show_badges and section.blocks.size > 0 %}
            <div class="u-cart__badges" data-announce>
              {% for block in section.blocks %}
                {%- if block.type == 'badge' -%}
                  <span class="u-ann__msg{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
                {%- endif -%}
              {% endfor %}
            </div>
          {% endif %}

          <div class="u-cart__body">
            {% for item in cart.items %}
              {%- liquid
                assign is_free = false
                if item.final_price == 0
                  assign is_free = true
                endif
                assign on_sale = false
                if item.variant.compare_at_price > item.variant.price
                  assign on_sale = true
                  assign ldisc = item.variant.compare_at_price | minus: item.variant.price | times: 100.0 | divided_by: item.variant.compare_at_price | round
                endif
              -%}
              <div class="u-cart__item" data-cart-item data-key="{{ item.key }}" data-qty="{{ item.quantity }}">
                <a class="u-cart__thumb" href="{{ item.url }}">
                  {% if item.image %}
                    {{ item.image | image_url: width: 180 | image_tag: loading: 'lazy', widths: '90,180', alt: item.title | escape }}
                  {% else %}
                    <span class="u-cart__thumb-ph">ॐ</span>
                  {% endif %}
                </a>
                <div class="u-cart__meta">
                  <a class="u-cart__name" href="{{ item.url }}">{{ item.product.title }}</a>
                  {% unless item.variant_title == blank %}<span class="u-cart__variant">{{ item.variant_title }}</span>{% endunless %}
                  {% if is_free %}
                    <span class="u-cart__free">FREE!{% if item.variant.compare_at_price > 0 %} <em>({{ item.variant.compare_at_price | money }} Value)</em>{% endif %}</span>
                  {% else %}
                    <div class="u-cart__price">
                      <span class="u-cart__now">{{ item.final_price | money }}</span>
                      {% if on_sale %}<span class="u-cart__was">{{ item.variant.compare_at_price | money }}</span><span class="u-cart__disc">-{{ ldisc }}%</span>{% endif %}
                    </div>
                  {% endif %}
                </div>
                <div class="u-cart__side">
                  <button type="button" class="u-cart__remove" data-cart-remove aria-label="Remove">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2M6 7l1 13a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1l1-13"/></svg>
                  </button>
                  {% unless is_free %}
                    <div class="u-cart__qty">
                      <button type="button" data-cart-minus aria-label="Decrease quantity">−</button>
                      <span data-cart-qty>{{ item.quantity }}</span>
                      <button type="button" data-cart-plus aria-label="Increase quantity">+</button>
                    </div>
                  {% endunless %}
                </div>
              </div>
            {% endfor %}
          </div>

          {% if section.settings.show_delivery %}
            <div class="u-cart__delivery">
              {% render 'upaasak-icon', icon: 'truck' %}
              <span>Estimated delivery by <strong>{{ eta }}</strong></span>
            </div>
          {% endif %}

          {% if section.settings.show_savings and savings > 0 %}
            <div class="u-cart__savings">
              {% render 'upaasak-icon', icon: 'sparkle' %}
              <span>You saved <strong>{{ savings | money }}</strong> on this order</span>
            </div>
          {% endif %}

          {% if section.settings.show_bill_summary %}
            <details class="u-cart__bill">
              <summary>
                <span class="u-cart__bill-head-closed">View Bill Details
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </span>
                <span class="u-cart__bill-head-open">Payment Summary
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
                </span>
              </summary>
              <div class="u-cart__bill-body">
                <div class="u-cart__bill-row"><span>MRP</span><span>{{ mrp_total | money }}</span></div>
                {% if item_discount > 0 %}
                  <div class="u-cart__bill-row u-cart__bill-row--disc"><span>Item Discount</span><span>-{{ item_discount | money }}</span></div>
                {% endif %}
                <div class="u-cart__bill-row"><span>Sub Total</span><span>{{ sub_total | money }}</span></div>
                <div class="u-cart__bill-divider"></div>
                <div class="u-cart__bill-row"><span>Shipping Charges</span><span{% if free_ship %} class="is-free"{% endif %}>{% if free_ship %}FREE{% else %}{{ flat_shipping | money }}{% endif %}</span></div>
              </div>
            </details>
          {% endif %}
        </div>

        <footer class="u-cart__foot">
          <div class="u-cart__total">
            <span>Total</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <a href="{{ routes.cart_url }}/checkout" class="u-btn u-btn--primary u-cart__checkout">{{ section.settings.checkout_label }}</a>
          <button type="button" class="u-btn u-btn--ghost u-cart__continue" data-cart-close>{{ section.settings.continue_label }}</button>

          {% if section.settings.returns_text != blank %}
            <p class="u-cart__returns">
              {% render 'upaasak-icon', icon: 'whatsapp' %}
              <span>{{ section.settings.returns_text }}{% if section.settings.returns_link != blank and section.settings.returns_link_text != blank %} <a href="{{ section.settings.returns_link }}" target="_blank" rel="noopener">{{ section.settings.returns_link_text }}</a>{% endif %}</span>
            </p>
          {% endif %}

          {% if section.settings.show_payments %}
            {% render 'upaasak-payments', methods: section.settings.payment_methods %}
          {% endif %}
        </footer>
      {% else %}
        <div class="u-cart__empty">
          <span class="u-cart__empty-ico">{% render 'upaasak-icon', icon: 'bead' %}</span>
          <h3>{{ section.settings.empty_title }}</h3>
          <p>{{ section.settings.empty_text }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="u-btn u-btn--primary" data-cart-close>{{ section.settings.empty_cta }}</a>
        </div>
      {% endif %}

    </div>
  </aside>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Your cart" },
    { "type": "text", "id": "checkout_label", "label": "Checkout button label", "default": "Buy Now" },
    { "type": "text", "id": "continue_label", "label": "Continue button label", "default": "Continue Shopping" },
    { "type": "header", "content": "Moving badges" },
    { "type": "checkbox", "id": "show_badges", "label": "Show rotating badge strip", "default": true },
    { "type": "header", "content": "Estimated delivery" },
    { "type": "checkbox", "id": "show_delivery", "label": "Show estimated delivery", "default": true },
    { "type": "number", "id": "delivery_days", "label": "Delivery days from today", "default": 7 },
    { "type": "header", "content": "Totals" },
    { "type": "checkbox", "id": "show_savings", "label": "Show savings banner", "default": true },
    { "type": "header", "content": "Payment Summary" },
    { "type": "checkbox", "id": "show_bill_summary", "label": "Show Payment Summary breakdown", "default": true },
    { "type": "number", "id": "free_ship_threshold", "label": "Free shipping threshold (rupees)", "default": 999 },
    { "type": "number", "id": "flat_shipping_rate", "label": "Shipping charge below threshold (rupees)", "default": 99 },
    { "type": "header", "content": "Trust" },
    { "type": "text", "id": "returns_text", "label": "Trust line text", "default": "Need Help?" },
    { "type": "text", "id": "returns_link_text", "label": "Trust line link text", "default": "WhatsApp us" },
    { "type": "url", "id": "returns_link", "label": "Trust line link (e.g. wa.me URL)" },
    { "type": "checkbox", "id": "show_payments", "label": "Show payment icons", "default": true },
    { "type": "text", "id": "payment_methods", "label": "Payment methods (comma-separated)", "info": "visa, mastercard, upi, rupay, paypal, gpay, amazon, applepay, cod", "default": "visa,mastercard,upi,rupay,paypal" },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_title", "label": "Empty title", "default": "Your cart is empty" },
    { "type": "textarea", "id": "empty_text", "label": "Empty text", "default": "Discover our sacred Rudraksha, malas and bracelets — energized and ready to bless." },
    { "type": "text", "id": "empty_cta", "label": "Empty button label", "default": "Continue Shopping" }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "You have got FREE Shipping" }
      ]
    }
  ]
}
{% endschema %}
