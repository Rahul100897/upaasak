{% render 'upaasak-design-system' %}

<section class="u-section u-sig" data-section-id="{{ section.id }}">
  <div class="u-wrap">
    <div class="u-sig__grid{% if section.settings.image_position == 'right' %} u-whyx--rev{% endif %}">
      <div class="u-sig__media" data-reveal="left">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '450,700,900', alt: section.settings.heading | escape }}
        {% else %}
          <div style="position:absolute;inset:0;display:grid;place-items:center;color:var(--u-maroon);font-family:var(--u-font-display);font-size:7rem;opacity:.5;">ॐ</div>
        {% endif %}
      </div>

      <div class="u-sig__content" data-reveal="right">
        {% if section.settings.eyebrow != blank %}<span class="u-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
        <h1 class="u-title">{{ section.settings.heading }}</h1>
        {% if section.settings.body != blank %}<div class="u-lead">{{ section.settings.body }}</div>{% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Content",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select", "id": "image_position", "label": "Image position", "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "About Upaasak" },
    {
      "type": "richtext", "id": "body", "label": "Body text",
      "default": "<p>Upaasak is home to authentic, lab-certified Rudraksha, Karungali and spiritual essentials — each piece sourced with devotion, energized with Vedic mantras, and delivered with care across India.</p><p>We exist to make genuine, ritually significant products accessible to every seeker, so your practice is built on trust, not guesswork.</p>"
    }
  ],
  "presets": [
    { "name": "About Content" }
  ]
}
{% endschema %}
