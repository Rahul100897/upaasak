{% render 'upaasak-design-system' %}

<section class="u-section u-contact" data-section-id="{{ section.id }}">
  <div class="u-wrap">
    <div class="u-section-head is-centered">
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal>{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:80ms">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}<p class="u-lead" data-reveal style="--d:160ms">{{ section.settings.subheading }}</p>{% endif %}
    </div>

    <div class="u-contact__grid u-contact__grid--single">
      {%- comment -%} RIGHT: contact form {%- endcomment -%}
      <div class="u-contact__formwrap" data-reveal="right">
        {% if section.settings.form_title != blank %}<h3 class="u-contact__form-title">{{ section.settings.form_title }}</h3>{% endif %}
        {% if section.settings.form_note != blank %}<p class="u-contact__form-note">{{ section.settings.form_note }}</p>{% endif %}

        {% form 'contact', class: 'u-contact__form' %}
          {% if form.posted_successfully? %}
            <div class="u-contact__success">
              <span>{% render 'upaasak-icon', icon: 'certificate' %}</span>
              <div>
                <strong>{{ section.settings.success_title }}</strong>
                <p>{{ section.settings.success_text }}</p>
              </div>
            </div>
          {% endif %}
          {% if form.errors %}
            <div class="u-contact__error">{{ form.errors | default_errors }}</div>
          {% endif %}

          <div class="u-contact__row">
            <label class="u-field">
              <span>Name</span>
              <input type="text" name="contact[name]" value="{{ form.name }}" placeholder="Your full name" required>
            </label>
            <label class="u-field">
              <span>Email</span>
              <input type="email" name="contact[email]" value="{{ form.email }}" placeholder="you@example.com" required>
            </label>
          </div>
          <label class="u-field">
            <span>Phone</span>
            <input type="tel" name="contact[phone]" value="{{ form.phone }}" placeholder="+91 " required>
          </label>
          <label class="u-field">
            <span>What can we help with?</span>
            <select name="contact[topic]" class="u-col__select">
              <option value="">Select a topic</option>
              <option value="Order Status / Tracking">Order Status / Tracking</option>
              <option value="Replacement Request">Replacement Request</option>
              <option value="Product Query">Product Query</option>
              <option value="Payment Issue">Payment Issue</option>
              <option value="General Enquiry">General Enquiry</option>
            </select>
          </label>
          <label class="u-field">
            <span>Message</span>
            <textarea name="contact[body]" rows="5" placeholder="How can we help you on your spiritual journey?" required>{{ form.body }}</textarea>
          </label>
          <button type="submit" class="u-btn u-btn--primary u-contact__submit">{{ section.settings.button_label }}</button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Contact",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "We're Here to Help" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in Touch" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "हम यहाँ हैं आपकी सेवा में" },
    { "type": "header", "content": "Form" },
    { "type": "text", "id": "form_title", "label": "Form title", "default": "Send us a message" },
    { "type": "text", "id": "form_note", "label": "Form note", "default": "We usually reply within 24 hours on working days (Mon-Sat, 10am-7pm IST)." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send Message" },
    { "type": "text", "id": "success_title", "label": "Success title", "default": "Message received" },
    { "type": "textarea", "id": "success_text", "label": "Success text", "default": "Thank you for reaching out. A member of our team will reply to your email shortly." },
    { "type": "header", "content": "Social links" },
    { "type": "checkbox", "id": "show_social", "label": "Show social icons", "default": true },
    { "type": "url", "id": "whatsapp", "label": "WhatsApp link" },
    { "type": "url", "id": "instagram", "label": "Instagram link" },
    { "type": "url", "id": "facebook", "label": "Facebook link" }
  ],
  "blocks": [
    {
      "type": "method",
      "name": "Contact method",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "mail",
          "options": [
            { "value": "mail", "label": "Email" },
            { "value": "phone", "label": "Phone" },
            { "value": "whatsapp", "label": "WhatsApp" },
            { "value": "pin", "label": "Location" },
            { "value": "clock", "label": "Hours" },
            { "value": "chat", "label": "Chat" },
            { "value": "headset", "label": "Support" }
          ]
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Email us" },
        { "type": "text", "id": "value", "label": "Value", "default": "support@upaasak.com" },
        { "type": "text", "id": "note", "label": "Sub-note" },
        { "type": "text", "id": "link", "label": "Link (mailto:, tel:, https:)", "info": "Leave empty for plain text (e.g. address)." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upaasak Contact",
      "blocks": [
        { "type": "method", "settings": { "icon": "mail", "label": "Email us", "value": "support@upaasak.com", "note": "We reply within 24 hours", "link": "mailto:support@upaasak.com" } },
        { "type": "method", "settings": { "icon": "phone", "label": "Call us", "value": "+91 90000 00000", "note": "Mon–Sat, 10am–7pm IST", "link": "tel:+919000000000" } },
        { "type": "method", "settings": { "icon": "whatsapp", "label": "WhatsApp", "value": "Chat with us", "note": "Fastest response", "link": "https://wa.me/919000000000" } },
        { "type": "method", "settings": { "icon": "pin", "label": "Visit us", "value": "Upaasak, India", "note": "By appointment", "link": "" } }
      ]
    }
  ]
}
{% endschema %}
