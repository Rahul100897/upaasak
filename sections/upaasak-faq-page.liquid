{% render 'upaasak-design-system' %}

<section class="u-section u-faq u-faqpage" data-section-id="{{ section.id }}">
  <div class="u-wrap u-wrap--narrow">
    <div class="u-section-head is-centered">
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal>{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:80ms">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}<p class="u-lead" data-reveal style="--d:160ms">{{ section.settings.subheading }}</p>{% endif %}
    </div>

    {%- assign i = 0 -%}
    <div class="u-faq__list" data-reveal>
      {% for block in section.blocks %}
        {%- case block.type -%}
        {%- when 'category' -%}
          <h3 class="u-faqpage__cat" {{ block.shopify_attributes }}>{{ block.settings.title }}</h3>
        {%- when 'faq' -%}
          <div class="u-faq__item{% if i == 0 and section.settings.open_first %} is-open{% endif %}" {{ block.shopify_attributes }}>
            <button type="button" class="u-faq__q">
              <span>{{ block.settings.question }}</span>
              <span class="u-faq__icon" aria-hidden="true"></span>
            </button>
            <div class="u-faq__a"{% if i == 0 and section.settings.open_first %} style="max-height:800px"{% endif %}>
              <div class="u-faq__a-inner">{{ block.settings.answer }}</div>
            </div>
          </div>
          {%- assign i = i | plus: 1 -%}
        {%- endcase -%}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Page",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Help Centre" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Everything you need to know about our sacred products, orders and care." },
    { "type": "checkbox", "id": "open_first", "label": "Open first item by default", "default": true }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category heading",
      "settings": [
        { "type": "text", "id": "title", "label": "Category title", "default": "General Questions" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is Rudraksha?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Rudraksha is a sacred seed associated with Lord Shiva, used for meditation and prayer.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page",
      "blocks": [
        { "type": "category", "settings": { "title": "General Questions" } },
        { "type": "faq" },
        { "type": "faq", "settings": { "question": "Are your products authentic?", "answer": "<p>Yes — every product is lab-certified for authenticity.</p>" } }
      ]
    }
  ]
}
{% endschema %}
