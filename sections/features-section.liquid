              <circle cx="12" cy="12" r="9"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          {% endif %}
        </div>
        <div class="feature-content">
          <h3 class="feature-title">{{ section.settings.feature2_title }}</h3>
          <p class="feature-description">{{ section.settings.feature2_description }}</p>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="feature-item">
        <div class="feature-icon">
          {% if section.settings.feature3_icon %}
            {{ section.settings.feature3_icon | image_url: width: 120 | image_tag: class: 'feature-icon-img' }}
          {% else %}
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 4v6h6M23 20v-6h-6"/>
              <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22-4l-4.64 4.36A9 9 0 0 1 3.51 15"/>
            </svg>
          {% endif %}
        </div>
        <div class="feature-content">
          <h3 class="feature-title">{{ section.settings.feature3_title }}</h3>
          <p class="feature-description">{{ section.settings.feature3_description }}</p>
        </div>
      </div>

      <!-- Feature 4 -->
      <div class="feature-item">
        <div class="feature-icon">
          {% if section.settings.feature4_icon %}
