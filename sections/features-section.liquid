{% stylesheet %}
  .features-section {
    background-color: #ffffff;
    padding: 60px 20px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .features-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 50px;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    transition: all 0.3s ease;
  }

  .feature-item:hover {
    transform: translateY(-5px);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
  }

  .feature-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .feature-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .feature-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-title {
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.3;
  }

  .feature-description {
    font-size: 14px;
    color: #666666;
    line-height: 1.6;
    margin: 0;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }

    .features-section {
      padding: 50px 20px;
    }
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
      gap: 35px;
    }

    .features-section {
      padding: 40px 15px;
    }

    .feature-title {
      font-size: 18px;
    }

    .feature-description {
      font-size: 13px;
    }
  }

  @media (max-width: 480px) {
    .features-grid {
      gap: 25px;
    }

    .features-section {
      padding: 30px 15px;
    }

    .feature-icon {
      width: 50px;
      height: 50px;
    }

    .feature-title {
      font-size: 16px;
    }

    .feature-description {
      font-size: 12px;
    }
  }
{% endstylesheet %}

<div class="features-section">
  <div class="features-container">
    <div class="features-grid">
      <!-- Feature 1 -->
      <div class="feature-item">
        <div class="feature-icon">
          {% if section.settings.feature1_icon %}
            {{ section.settings.feature1_icon | image_url: width: 120 | image_tag: class: 'feature-icon-img' }}
          {% else %}
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.13v-5.36c0-.87-.46-1.66-1.19-2.09l-8.4-5.32a2.5 2.5 0 0 0-2.82 0L2.19 3.68C1.46 4.11 1 4.9 1 5.77v5.36c0 .87.46 1.66 1.19 2.09l8.4 5.32a2.5 2.5 0 0 0 2.82 0l8.4-5.32c.73-.43 1.19-1.22 1.19-2.09Z"/>
            </svg>
          {% endif %}
        </div>
        <div class="feature-content">
          <h3 class="feature-title">{{ section.settings.feature1_title }}</h3>
          <p class="feature-description">{{ section.settings.feature1_description }}</p>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="feature-item">
        <div class="feature-icon">
          {% if section.settings.feature2_icon %}
            {{ section.settings.feature2_icon | image_url: width: 120 | image_tag: class: 'feature-icon-img' }}
