{% render 'upaasak-design-system' %}

<section class="u-section u-cta" data-section-id="{{ section.id }}">
  {% if section.settings.bg_image != blank %}
    <img class="u-cta__bg" src="{{ section.settings.bg_image | image_url: width: 2000 }}" alt="" loading="lazy">
  {% endif %}
  <div class="u-wrap">
    <div class="u-cta__inner">
      <div class="u-divider" data-reveal><span>ॐ</span></div>
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal style="--d:60ms">{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:120ms">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}<p class="u-cta__sub" data-reveal style="--d:200ms">{{ section.settings.subheading }}</p>{% endif %}

      {% if section.settings.show_form %}
        <form class="u-cta__form" method="post" action="/contact#contact_form" data-reveal style="--d:280ms">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required>
          <button type="submit" class="u-btn u-btn--gold">{{ section.settings.btn_label }}</button>
        </form>
      {% else %}
        <div class="u-hero__cta" style="justify-content:center" data-reveal style="--d:280ms">
          {% if section.settings.btn_label != blank %}<a href="{{ section.settings.btn_link | default: '#' }}" class="u-btn u-btn--gold">{{ section.settings.btn_label }}</a>{% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Upaasak CTA Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background image (optional)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Begin Your Journey" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Bring Sacred Energy <em>Into Your Day</em>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Join our circle for spiritual guidance, new arrivals and devotee-only offers — plus your free Rudraksha care guide." },
    { "type": "checkbox", "id": "show_form", "label": "Show email signup form", "default": true },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "Enter your email" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Join the Circle" },
    { "type": "url", "id": "btn_link", "label": "Button link (when form is hidden)" }
  ],
  "presets": [
    { "name": "Upaasak CTA Banner" }
  ]
}
{% endschema %}
