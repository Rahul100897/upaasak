{% render 'upaasak-design-system' %}

{%- liquid
  assign coll = section.settings.collection
  if coll == blank or coll.products.size == 0
    assign coll = collections.all
  endif
-%}

<section class="u-section u-sec u-sec--ivory" data-section-id="{{ section.id }}">
  <div class="u-wrap">
    <div class="u-section-head is-centered">
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal>{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:60ms">{% if section.settings.heading_lead != blank %}<span class="u-title__lead">{{ section.settings.heading_lead }}</span> {% endif %}<em>{{ section.settings.heading_accent }}</em></h2>
    </div>

    {% if coll != blank and coll.products.size > 0 %}
      <div class="u-scroller" data-scroller data-reveal style="--d:120ms">
        <button type="button" class="u-scroller__arrow u-scroller__arrow--prev" data-scroll-prev aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
        </button>
        <div class="u-prow" data-scroll>
          {% for product in coll.products limit: section.settings.count %}
            {% render 'upaasak-product-card', product: product %}
          {% endfor %}
        </div>
        <button type="button" class="u-scroller__arrow u-scroller__arrow--next" data-scroll-next aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      </div>
      {% if section.settings.show_view_all %}
        <div class="u-viewall">
          <a href="{{ coll.url | default: routes.all_products_collection_url }}" class="u-btn u-btn--ghost">{{ section.settings.view_all_label }}</a>
        </div>
      {% endif %}
    {% else %}
      <p style="text-align:center;color:var(--u-muted);padding:30px 0">Select a collection in the theme editor.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Best Seller",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "" },
    { "type": "text", "id": "heading_lead", "label": "Heading (regular)", "info": "e.g. Best", "default": "Best" },
    { "type": "text", "id": "heading_accent", "label": "Heading (bold/maroon)", "info": "e.g. Seller", "default": "Seller" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "count", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 4 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show View All button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All" }
  ],
  "presets": [
    {
      "name": "Upaasak Best Seller",
      "settings": { "count": 4 }
    }
  ]
}
{% endschema %}
