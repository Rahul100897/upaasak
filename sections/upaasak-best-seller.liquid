{% render 'upaasak-design-system' %}

{%- liquid
  assign coll = section.settings.collection
  if coll == blank or coll.products.size == 0
    assign coll = collections.all
  endif
-%}

<section class="u-section u-sec u-sec--ivory" data-section-id="{{ section.id }}">
  <div class="u-wrap">
    <div class="u-section-head is-centered">
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal>{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:60ms">{{ section.settings.heading }}</h2>
    </div>

    {% if coll != blank and coll.products.size > 0 %}
      <div class="u-grid4" data-reveal style="--d:120ms">
        {% for product in coll.products limit: section.settings.count %}
          {% render 'upaasak-product-card', product: product %}
        {% endfor %}
      </div>
      {% if section.settings.show_view_all %}
        <div class="u-viewall">
          <a href="{{ coll.url | default: routes.all_products_collection_url }}" class="u-btn u-btn--ghost">{{ section.settings.view_all_label }}</a>
        </div>
      {% endif %}
    {% else %}
      <p style="text-align:center;color:var(--u-muted);padding:30px 0">Select a collection in the theme editor.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Best Seller",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Most Loved" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Best Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "count", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 4 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show View All button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All" }
  ],
  "presets": [
    {
      "name": "Upaasak Best Seller",
      "settings": { "count": 4 }
    }
  ]
}
{% endschema %}
