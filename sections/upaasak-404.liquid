{% render 'upaasak-design-system' %}

{%- liquid
  assign fc = section.settings.featured_collection
  if fc == blank
    assign fc = collections['all']
  endif
-%}

<section class="u-section u-404" data-section-id="{{ section.id }}">
  <div class="u-wrap u-404__inner">
    <div class="u-404__big" data-reveal aria-hidden="true">4<span class="u-404__om u-shimmer">ॐ</span>4</div>
    {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal style="--d:80ms">{{ section.settings.eyebrow }}</span>{% endif %}
    <h1 class="u-title" data-reveal style="--d:140ms">{{ section.settings.heading }}</h1>
    {% if section.settings.subtext != blank %}<p class="u-lead" data-reveal style="--d:200ms">{{ section.settings.subtext }}</p>{% endif %}

    {% if section.settings.show_search %}
      <div class="u-404__search u-srch__bar" data-psearch data-reveal style="--d:260ms">
        <form action="{{ routes.search_url }}" method="get" class="u-search" role="search" autocomplete="off">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5" stroke-linecap="round"/></svg>
          <input type="search" name="q" placeholder="{{ section.settings.search_placeholder }}" autocomplete="off" data-psearch-input aria-label="Search">
          <input type="hidden" name="type" value="product">
          <input type="hidden" name="options[prefix]" value="last">
          <button type="button" class="u-search-clear" data-psearch-clear aria-label="Clear search" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
          </button>
        </form>
        <div class="u-psearch" data-psearch-results role="listbox" aria-label="Search suggestions"></div>
      </div>
    {% endif %}

    <div class="u-404__cta" data-reveal style="--d:320ms">
      <a href="{{ routes.root_url }}" class="u-btn u-btn--primary">{{ section.settings.home_label }}</a>
      <a href="{{ routes.all_products_collection_url }}" class="u-btn u-btn--ghost">{{ section.settings.shop_label }}</a>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="u-404__links" data-reveal style="--d:380ms">
        {% for block in section.blocks %}
          <a href="{{ block.settings.link | default: routes.all_products_collection_url }}" class="u-404__link" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}{% render 'upaasak-icon', icon: block.settings.icon %}{% endif %}
            {{ block.settings.label }}
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {% if section.settings.show_featured and fc != blank and fc.products.size > 0 %}
    <div class="u-wrap u-404__featured">
      <div class="u-section-head is-centered">
        <h2 class="u-title" data-reveal>{{ section.settings.featured_heading }}</h2>
      </div>
      <div class="u-grid4">
        {% for product in fc.products limit: 4 %}
          {% render 'upaasak-product-card', product: product %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "404 Page",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Lost on your path?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This Page Could Not Be Found" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "The link may be broken or the page may have moved. Let's guide you back to something sacred." },
    { "type": "text", "id": "home_label", "label": "Primary button label", "default": "Back to Home" },
    { "type": "text", "id": "shop_label", "label": "Secondary button label", "default": "Shop All" },
    { "type": "header", "content": "Search" },
    { "type": "checkbox", "id": "show_search", "label": "Show search bar", "default": true },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Search for Rudraksha, Mala, Bracelets…" },
    { "type": "header", "content": "Featured products" },
    { "type": "checkbox", "id": "show_featured", "label": "Show featured products", "default": true },
    { "type": "text", "id": "featured_heading", "label": "Featured heading", "default": "You May Like These" },
    { "type": "collection", "id": "featured_collection", "label": "Collection", "info": "Falls back to all products if empty." }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Quick link",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "bead",
          "options": [
            { "value": "bead", "label": "Bead" },
            { "value": "lotus", "label": "Lotus" },
            { "value": "gem", "label": "Gem" },
            { "value": "gift", "label": "Gift" },
            { "value": "om", "label": "Om" },
            { "value": "mantra", "label": "Mala" }
          ]
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Rudraksha" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "404 Page",
      "blocks": [
        { "type": "link", "settings": { "icon": "bead", "label": "Rudraksha" } },
        { "type": "link", "settings": { "icon": "gem", "label": "Bracelets" } },
        { "type": "link", "settings": { "icon": "mantra", "label": "Mala" } },
        { "type": "link", "settings": { "icon": "gift", "label": "Gifting" } }
      ]
    }
  ]
}
{% endschema %}
