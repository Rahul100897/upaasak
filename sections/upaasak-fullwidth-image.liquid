{% render 'upaasak-design-system' %}

<section class="u-section u-fwimg" data-section-id="{{ section.id }}">
  {%- if section.settings.link != blank -%}<a class="u-fwimg__link" href="{{ section.settings.link }}" aria-label="{{ section.settings.alt | default: 'Banner' | escape }}">{%- endif -%}
    {% if section.settings.image != blank %}
      <picture class="u-fwimg__pic">
        {% if section.settings.image_mobile != blank %}
          <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 1200 }}" width="{{ section.settings.image_mobile.width }}" height="{{ section.settings.image_mobile.height }}">
        {% endif %}
        <img class="u-fwimg__img" src="{{ section.settings.image | image_url: width: 2400 }}" alt="{{ section.settings.alt | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy">
      </picture>
    {% else %}
      <div class="u-fwimg__ph">Add a full-width image</div>
    {% endif %}
  {%- if section.settings.link != blank -%}</a>{%- endif -%}
</section>

{% schema %}
{
  "name": "Full-width Image",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Edge-to-edge image (no padding). Add a separate mobile crop for phones." },
    { "type": "image_picker", "id": "image", "label": "Image (desktop)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Image (mobile)" },
    { "type": "url", "id": "link", "label": "Link (optional)" },
    { "type": "text", "id": "alt", "label": "Alt text", "default": "Upaasak" }
  ],
  "presets": [
    { "name": "Full-width Image" }
  ]
}
{% endschema %}
