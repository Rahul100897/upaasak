{% render 'upaasak-design-system' %}

<section class="u-section u-site" data-section-id="{{ section.id }}">
  <div class="u-site__grid">
    <div class="u-site__brand">
      {% comment %} <a class="u-lockup" href="{{ routes.root_url }}">
        <span class="u-lockup__mark">{{ section.settings.logo_letter }}</span>
        <span>
          <span class="u-lockup__name">{{ section.settings.brand_name }}</span>
          <span class="u-lockup__slogan">{{ section.settings.slogan }}</span>
        </span>
      </a> {% endcomment %}
      <a class="u-lockup" href="/">
        <img src="https://upaasak.com/cdn/shop/files/Logo_logo-new.png" alt="Upaasak" width="48" height="48" style=" width: 180px; padding: 5px; background: #fff; ">
          {% comment %} <span>
            <span class="u-lockup__name">UPAASAK</span>
            <span class="u-lockup__slogan"></span>
          </span> {% endcomment %}
      </a>
      <p>{{ section.settings.about }}</p>
      <div class="u-site__social">
        {% if section.settings.whatsapp != blank %}
          <a class="wa" href="{{ section.settings.whatsapp }}" aria-label="WhatsApp" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.3A10 10 0 1 0 12 2Zm5.1 14.1c-.2.6-1.2 1.1-1.7 1.2-.5.1-1 .2-3.2-.7-2.7-1.1-4.4-3.8-4.5-4-.1-.2-1.1-1.4-1.1-2.7s.7-1.9.9-2.2c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.5c-.1.2-.3.3-.1.6.1.2.6 1 1.3 1.6.9.8 1.6 1 1.8 1.1.2.1.4.1.5-.1l.6-.8c.2-.2.4-.2.6-.1l1.8.9c.2.1.4.2.4.3.1.2.1.7-.1 1.3Z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.instagram != blank %}
          <a class="ig" href="{{ section.settings.instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.3" cy="6.7" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    {% for block in section.blocks %}
      {% if block.type == 'contact' %}
        <div class="u-site__col u-site__contact" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title }}</h4>
          <ul class="u-site__cinfo">
            {% if block.settings.email != blank %}
              <li><a href="mailto:{{ block.settings.email }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg><span>{{ block.settings.email }}</span></a></li>
            {% endif %}
            {% if block.settings.phone != blank %}
              <li><a href="tel:{{ block.settings.phone | remove: ' ' }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11 11 0 0 0 3.5.56 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11 11 0 0 0 .56 3.5 1 1 0 0 1-.24 1Z"/></svg><span>{{ block.settings.phone }}</span></a></li>
            {% endif %}
            {% if block.settings.address != blank %}
              <li class="u-site__cstatic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.2-7-10.5A4.5 4.5 0 0 1 12 6a4.5 4.5 0 0 1 7 4.5C19 15.8 12 21 12 21Z"/><circle cx="12" cy="10.5" r="2"/></svg><span>{{ block.settings.address }}</span></li>
            {% endif %}
          </ul>
          <div class="u-site__social">
            {% if block.settings.whatsapp != blank %}<a class="wa" href="{{ block.settings.whatsapp }}" aria-label="WhatsApp" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.3A10 10 0 1 0 12 2Zm5.1 14.1c-.2.6-1.2 1.1-1.7 1.2-.5.1-1 .2-3.2-.7-2.7-1.1-4.4-3.8-4.5-4-.1-.2-1.1-1.4-1.1-2.7s.7-1.9.9-2.2c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.5c-.1.2-.3.3-.1.6.1.2.6 1 1.3 1.6.9.8 1.6 1 1.8 1.1.2.1.4.1.5-.1l.6-.8c.2-.2.4-.2.6-.1l1.8.9c.2.1.4.2.4.3.1.2.1.7-.1 1.3Z"/></svg></a>{% endif %}
            {% if block.settings.instagram != blank %}<a class="ig" href="{{ block.settings.instagram }}" aria-label="Instagram" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.3" cy="6.7" r="1" fill="currentColor" stroke="none"/></svg></a>{% endif %}
            {% if block.settings.facebook != blank %}<a class="fb" href="{{ block.settings.facebook }}" aria-label="Facebook" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-2 0-3 1.3-3 3.2V11H9v3h2v6h3v-6h2.3l.7-3H14V9.6c0-.4.3-.6.6-.6Z"/></svg></a>{% endif %}
            {% if block.settings.youtube != blank %}<a class="yt" href="{{ block.settings.youtube }}" aria-label="YouTube" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12s0-3-.4-4.4a2.5 2.5 0 0 0-1.8-1.8C18.4 5.4 12 5.4 12 5.4s-6.4 0-7.8.4A2.5 2.5 0 0 0 2.4 7.6C2 9 2 12 2 12s0 3 .4 4.4a2.5 2.5 0 0 0 1.8 1.8c1.4.4 7.8.4 7.8.4s6.4 0 7.8-.4a2.5 2.5 0 0 0 1.8-1.8C22 15 22 12 22 12ZM10 15V9l5 3Z"/></svg></a>{% endif %}
          </div>
        </div>
      {% else %}
        <div class="u-site__col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title }}</h4>
          <ul>
            {% if block.settings.l1 != blank %}<li><a href="{{ block.settings.u1 | default: '#' }}">{{ block.settings.l1 }}</a></li>{% endif %}
            {% if block.settings.l2 != blank %}<li><a href="{{ block.settings.u2 | default: '#' }}">{{ block.settings.l2 }}</a></li>{% endif %}
            {% if block.settings.l3 != blank %}<li><a href="{{ block.settings.u3 | default: '#' }}">{{ block.settings.l3 }}</a></li>{% endif %}
            {% if block.settings.l4 != blank %}<li><a href="{{ block.settings.u4 | default: '#' }}">{{ block.settings.l4 }}</a></li>{% endif %}
            {% if block.settings.l5 != blank %}<li><a href="{{ block.settings.u5 | default: '#' }}">{{ block.settings.l5 }}</a></li>{% endif %}
          </ul>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  <div class="u-site__bar">
    <span>{{ section.settings.copyright }}</span>
    <span>{{ section.settings.bottom_note }}</span>
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Sitemap Footer",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "logo_letter", "label": "Logo mark", "default": "Om" },
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "UPAASAK" },
    { "type": "text", "id": "slogan", "label": "Slogan", "default": "Authentic Spiritual Essentials" },
    { "type": "textarea", "id": "about", "label": "About text", "default": "Authentic, lab-certified and energized Rudraksha, malas and spiritual essentials, sourced with devotion and delivered across India." },
    { "type": "url", "id": "whatsapp", "label": "WhatsApp link" },
    { "type": "url", "id": "instagram", "label": "Instagram link" },
    { "type": "text", "id": "copyright", "label": "Copyright line", "default": "2026 UPAASAK. All rights reserved." },
    { "type": "text", "id": "bottom_note", "label": "Bottom note", "default": "Made with devotion in India" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title", "default": "Information" },
        { "type": "text", "id": "l1", "label": "Link 1 label" },
        { "type": "url", "id": "u1", "label": "Link 1 URL" },
        { "type": "text", "id": "l2", "label": "Link 2 label" },
        { "type": "url", "id": "u2", "label": "Link 2 URL" },
        { "type": "text", "id": "l3", "label": "Link 3 label" },
        { "type": "url", "id": "u3", "label": "Link 3 URL" },
        { "type": "text", "id": "l4", "label": "Link 4 label" },
        { "type": "url", "id": "u4", "label": "Link 4 URL" },
        { "type": "text", "id": "l5", "label": "Link 5 label" },
        { "type": "url", "id": "u5", "label": "Link 5 URL" }
      ]
    },
    {
      "type": "contact",
      "name": "Contact column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Get in Touch" },
        { "type": "text", "id": "email", "label": "Email" },
        { "type": "text", "id": "phone", "label": "Phone" },
        { "type": "text", "id": "address", "label": "Address (optional)" },
        { "type": "header", "content": "Social links" },
        { "type": "url", "id": "whatsapp", "label": "WhatsApp" },
        { "type": "url", "id": "instagram", "label": "Instagram" },
        { "type": "url", "id": "facebook", "label": "Facebook" },
        { "type": "url", "id": "youtube", "label": "YouTube" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upaasak Sitemap Footer",
      "blocks": [
        { "type": "column", "settings": { "title": "Information", "l1": "Contact us", "l2": "Blogs", "l3": "FAQs", "l4": "Free PDFs" } },
        { "type": "column", "settings": { "title": "Policies", "l1": "Terms & Conditions", "l2": "Privacy Policy", "l3": "Shipping Policy", "l4": "Refunds & Cancellations" } },
        { "type": "contact", "settings": { "title": "Get in Touch", "email": "hello@upaasak.com", "phone": "+91 00000 00000" } }
      ]
    }
  ]
}
{% endschema %}
