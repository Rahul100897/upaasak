{% render 'upaasak-design-system' %}

<section class="u-section u-trustbanner" data-section-id="{{ section.id }}">
  <div class="u-wrap">
    <div class="u-trustbanner__grid">
      {% for block in section.blocks %}
        <div class="u-trustbanner__card" data-reveal style="--d:{{ forloop.index0 | times: 80 }}ms" {{ block.shopify_attributes }}>
          <span class="u-trustbanner__icon">{% render 'upaasak-icon', icon: block.settings.icon %}</span>
          <h3 class="u-trustbanner__head">{{ block.settings.heading }}</h3>
          {% if block.settings.subtext != blank %}<p class="u-trustbanner__sub">{{ block.settings.subtext }}</p>{% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Banner",
  "tag": "section",
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "truck",
          "options": [
            { "value": "truck", "label": "Shipping" },
            { "value": "headset", "label": "Support" },
            { "value": "certificate", "label": "Certificate" },
            { "value": "om", "label": "Om" },
            { "value": "shield", "label": "Shield" },
            { "value": "return", "label": "Returns" },
            { "value": "lock", "label": "Secure" },
            { "value": "leaf", "label": "Leaf" }
          ]
        },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Free Shipping" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "No minimum order value. Delivered Pan India." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Banner",
      "blocks": [
        { "type": "tile", "settings": { "icon": "truck", "heading": "Free Shipping", "subtext": "No minimum order value. Delivered Pan India." } },
        { "type": "tile", "settings": { "icon": "headset", "heading": "Devotee Support", "subtext": "Reach us anytime via WhatsApp or Email." } },
        { "type": "tile", "settings": { "icon": "certificate", "heading": "OSOC Certified", "subtext": "QR code on every product links to original lab report." } },
        { "type": "tile", "settings": { "icon": "om", "heading": "Energized", "subtext": "Ready to wear. No activation needed." } }
      ]
    }
  ]
}
{% endschema %}
