{%- comment -%}
  Hero Section for Lesure PDP
{%- endcomment -%}

{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image

  assign show_size_guide = false
  for option in product.options_with_values
    if option.name contains 'Size' or option.name contains 'Größe'
      assign show_size_guide = true
      break
    endif
  endfor
-%}

{{ 'lesure-hero.css' | asset_url | stylesheet_tag }}

<div class="hero">
  <div class="hero-left">
    <div class="gallery">
      <div class="img-unit">
        <div class="gallery-slides" id="gallerySlides">
          <div class="gallery-track" id="galleryTrack">
            {%- for media in product.media -%}
              <div class="gallery-slide" data-media-id="{{ media.id }}" >
                {%- case media.media_type -%}
                  {%- when 'image' -%}
                    <img 
                      src="{{ media | image_url: width: 1000 }}" 
                      alt="{{ media.alt | escape }}"
                      data-gallery-alt="{{ media.alt | downcase | escape }}"
                      loading="lazy" 
                      class="main-img"
                    >
                  {%- when 'video' -%}
                    {{ media | video_tag: image_size: '1000x' }}
                  {%- when 'external_video' -%}
                    {{ media | external_video_tag: image_size: '1000x' }}
                  {%- when 'model' -%}
                    {{ media | model_viewer_tag }}
                  {%- else -%}
                    <img src="{{ media | image_url: width: 1000 }}" alt="{{ media.alt | escape }}" loading="lazy">
                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
          <button class="gallery-arrow prev hidden" id="galleryPrev" onclick="galleryMove(-1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="gallery-arrow next" id="galleryNext" onclick="galleryMove(1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 6 15 12 9 18"/></svg>
          </button>
        </div>
        <div class="thumbrow-inner">
          {%- for media in product.media -%}
            <div class="thumb" onclick="galleryGoTo({{ forloop.index0 }})">
              <img 
                  src="{{ media | image_url: width: 100 }}" 
                  alt="{{ media.alt | escape }}"
                  data-gallery-alt="{{ media.alt | downcase | escape }}"
                  loading="lazy"
                >
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  <div class="buy">
    <div class="product-tag">{% if product.tags.size > 0 %}
  <span class="product-first-tag">{{ product.tags[0] }}</span>
{% endif %}
</div>
    <div class="starsrow">
      <span class="stars">{{ section.settings.stars_rating }}</span>
      <span class="revlink" onclick="document.querySelector('.rvsec').scrollIntoView({behavior:'smooth'})" style="cursor:pointer;">{{ section.settings.reviews_text }}</span>
    </div>
    
    <div class="product-description">
      <h1 class="ptitle">{{ product.title }}</h1>
      {{ product.description }}
    </div>

    <div class="hdiv"></div>

    <div class="price-block">
      <span class="price-now" id="priceNow">{{ current_variant.price | money }}</span>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <span class="price-was" id="priceWas">{{ current_variant.compare_at_price | money }}</span>
        <span class="price-save" id="priceSave">save {{ current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price }}%</span>
      {%- endif -%}
    </div>
  
    {% form 'product', product, id: 'product-form-ajax' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}" id="variantIdInput">

      <button type="submit" name="add" class="btn-primary" id="desktopCta">
        <span class="btn-text">Add to cart — {{ current_variant.price | money }}</span>
        <span class="btn-loader" style="display:none;">Loading...</span>
      </button>
    {% endform %}

    <p class="price-note">{{ section.settings.price_note }}</p>

    <div class="gifts">
      {%- for block in section.blocks -%}
        {%- if block.type == 'gift_item' -%}
          <div class="gift-row">
            <div class="gift-text">{{ block.settings.text }} <span>— {{ block.settings.sub_text }}</span></div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="buy-acc">
      {%- for block in section.blocks -%}
        {%- if block.type == 'accordion_item' -%}
          <div class="buy-acc-item">
            <button class="buy-acc-q" onclick="toggleBuyAcc(this)">
              <span>{{ block.settings.title }}</span>
              <span class="buy-acc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></span>
            </button>
            <div class="buy-acc-a"><div class="buy-acc-a-inner">
              {{ block.settings.content_richtext }}
            </div></div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  window.productVariants = {{ product.variants | json }};
  window.selectedOptions = {{ current_variant.options | json }};
  window.shopCurrency = {{ shop.currency.iso_code | json }};
</script>
<script src="{{ 'lesure-hero.js' | asset_url }}" defer="defer"></script>

