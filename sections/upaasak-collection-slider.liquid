{% render 'upaasak-design-system' %}

<section class="u-section u-sec u-sec--ivory u-cslide" data-section-id="{{ section.id }}">
  <div class="u-wrap">
    <div class="u-section-head is-centered">
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal>{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:60ms">{% if section.settings.heading_lead != blank %}<span class="u-title__lead">{{ section.settings.heading_lead }}</span> {% endif %}<em>{{ section.settings.heading_accent }}</em></h2>
      {% if section.settings.subheading != blank %}<p class="u-lead" data-reveal style="--d:120ms">{{ section.settings.subheading }}</p>{% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="u-scroller" data-scroller data-reveal style="--d:160ms">
        <button type="button" class="u-scroller__arrow u-scroller__arrow--prev" data-scroll-prev aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
        </button>
        <div class="u-prow u-cslide__row" data-scroll>
          {% for block in section.blocks %}
            {%- assign coll = block.settings.collection -%}
            {% if coll != blank %}
              <a class="u-cslide__card" href="{{ coll.url }}" {{ block.shopify_attributes }}>
                <div class="u-cslide__media">
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 640 | image_tag: loading: 'lazy', widths: '320,480,640', alt: coll.title | escape }}
                  {% elsif coll.image != blank %}
                    {{ coll.image | image_url: width: 640 | image_tag: loading: 'lazy', widths: '320,480,640', alt: coll.title | escape }}
                  {% elsif coll.products.first.featured_image != blank %}
                    {{ coll.products.first.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', widths: '320,480,640', alt: coll.title | escape }}
                  {% else %}
                    <span class="u-cslide__ph">ॐ</span>
                  {% endif %}
                </div>
                <div class="u-cslide__body">
                  <h3>{{ block.settings.title | default: coll.title }}</h3>
                  <span class="u-cslide__count">{{ coll.all_products_count }} product{% if coll.all_products_count != 1 %}s{% endif %}</span>
                </div>
                <span class="u-cslide__go" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
              </a>
            {% endif %}
          {% endfor %}
        </div>
        <button type="button" class="u-scroller__arrow u-scroller__arrow--next" data-scroll-next aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      </div>
    {% else %}
      <p style="text-align:center;color:var(--u-muted);padding:30px 0">Add collection blocks in the theme editor.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Shop by Collection",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading_lead", "label": "Heading (regular)", "info": "e.g. Shop by", "default": "Shop by" },
    { "type": "text", "id": "heading_accent", "label": "Heading (bold/maroon)", "info": "e.g. Collection", "default": "Collection" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Custom title (optional)" },
        { "type": "image_picker", "id": "image", "label": "Custom image (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Collection",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
