{% stylesheet %}
.footer-section {
    background-color: #73252d;
    color: #000000;
    font-family: -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif;
    background-image: url(https://upaasak.vercel.app/images/footer-bg1.png);
    background-image: url(https://cdn.shopify.com/s/files/1/0814/0659/1194/files/footer-bg.png?v=1781297415);
    background-repeat: no-repeat;
    background-size: cover;
}

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Newsletter Section */
  .newsletter-wrapper {
    padding: 60px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .newsletter-content h2 {
      font-size: 38px;
      font-weight: 300;
      line-height: 52px;
      margin: 0;
      font-family: Georgia, Garamond, serif;
      letter-spacing: .5px;
      max-width: 550px;
  }
  img.footer-logo {
    max-width: 80px;
}

  .newsletter-form {
    display: flex;
    gap: 0;
    align-items: flex-end;
  }

  .newsletter-input-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .newsletter-input-wrapper label {
    font-size: 14px;
    color: #000;
    text-transform: lowercase;
    letter-spacing: 0.5px;
  }

  .newsletter-form input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgb(0 0 0 / 50%);
    color: #000;
    padding: 12px 0;
    font-size: 16px;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .newsletter-form input::placeholder {
    color: #000;
  }

  .newsletter-form input:focus {
    border-bottom-color: #000;
  }

.newsletter-submit {
    background-color: #7d0e2c;
    color: #fdf2e9;
    border: 2px solid #ffffff;
    padding: 15px 40px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all .3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
}

  .newsletter-submit:hover {
    background-color: #000;
    color: #ffffff;
  }

  /* Main Footer Content */
  .footer-main {
    padding: 40px 0;
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 1fr;
    gap: 80px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .footer-brand-name {
    font-size: 48px;
    font-weight: 400;
    font-family: 'Georgia', 'Garamond', serif;
    margin: 0;
    font-style: italic;
    letter-spacing: 1px;
  }

.footer-brand-desc {
    font-size: 14px;
    line-height: 1.8;
    color: #7a0d2c;
    max-width: 280px;
    margin: 0px;
}
  .social-icons {
    display: flex;
    gap: 15px;
  }

  .social-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: #7c1030;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #fff;
    transition: all 0.3s ease;
    font-size: 18px;
  }

  .social-icon:hover {
    background-color: #000000;
    transform: translateY(-3px);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .footer-column-title {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0;
    color: #77102c;
  }

.footer-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
}

  .footer-links li a {
      color: #780a2b;
      text-decoration: none;
      font-size: 15px;
      transition: color .3s ease;
      line-height: normal;
  }

  .footer-links li a:hover {
    color: #000;
  }
  .social-icon path {
      fill: #fff;
  }

  /* Footer Bottom */
  .footer-bottom {
      padding: 10px 0px 20px 0px;
      border-top: 1px solid rgba(255, 255, 255, .15);
      display: flex;
      gap: 30px;
      justify-content: center;
  }

  .footer-bottom-left {
    display: flex;
    gap: 40px;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-copyright {
      font-size: 14px;
      color: #000000b3;
      margin: 0;
      font-weight: 500;
  }

  .footer-bottom-links {
    display: flex;
    gap: 30px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-bottom-links a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s ease;
  }

  .footer-bottom-links a:hover {
    color: #ffffff;
  }

  .payment-methods {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .payment-icon {
    height: 28px;
    width: auto;
    max-width: 50px;
    object-fit: contain;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .newsletter-wrapper {
      grid-template-columns: 1fr;
      gap: 30px;
      padding: 40px 0;
    }

    .newsletter-content h2 {
      font-size: 36px;
    }

    .footer-main {
      grid-template-columns: 1fr 1fr;
      gap: 50px;
      padding: 50px 0;
    }
  }

  @media (max-width: 768px) {
    .newsletter-wrapper {
      padding: 30px 0;
    }

    .newsletter-content h2 {
      font-size: 28px;
    }

    .newsletter-form {
      flex-direction: column;
      gap: 20px;
    }

    .newsletter-submit {
      width: 100%;
    }

    .footer-main {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 0;
    }

    .footer-brand-name {
      font-size: 36px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 20px;
    }

    .footer-bottom-left {
      flex-direction: column;
      gap: 20px;
      width: 100%;
    }

    .footer-bottom-links {
      flex-direction: column;
      gap: 15px;
    }

    .payment-methods {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .footer-section {
      padding: 30px 15px;
    }

    .newsletter-content h2 {
      font-size: 22px;
    }

    .footer-brand-name {
      font-size: 28px;
    }

    .footer-column-title {
      font-size: 11px;
    }

    .footer-copyright {
      font-size: 12px;
    }

    .footer-bottom-links a {
      font-size: 12px;
    }

    .payment-methods {
      flex-wrap: wrap;
    }
  }
{% endstylesheet %}

