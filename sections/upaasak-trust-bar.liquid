{% render 'upaasak-design-system' %}

<section class="u-section u-trustbar" data-section-id="{{ section.id }}">
  <div class="u-trustbar__in">
    {% for block in section.blocks %}
      <div class="u-trustbar__item" {{ block.shopify_attributes }}>
        {% render 'upaasak-icon', icon: block.settings.icon %}
        <span>{{ block.settings.text }}</span>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Trust Bar",
  "tag": "section",
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "certificate",
          "options": [
            { "value": "certificate", "label": "Certificate" }, { "value": "om", "label": "Om" },
            { "value": "leaf", "label": "Leaf" }, { "value": "shield", "label": "Shield" },
            { "value": "truck", "label": "Shipping" }, { "value": "return", "label": "Returns" },
            { "value": "lock", "label": "Secure" }, { "value": "headset", "label": "Support" }
          ]
        },
        { "type": "text", "id": "text", "label": "Text", "default": "100% Original & Certified" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upaasak Trust Bar",
      "blocks": [
        { "type": "usp", "settings": { "icon": "certificate", "text": "100% Original & Lab-Certified" } },
        { "type": "usp", "settings": { "icon": "om", "text": "Energized with Vedic Mantras" } },
        { "type": "usp", "settings": { "icon": "truck", "text": "Free Shipping Above ₹999" } },
        { "type": "usp", "settings": { "icon": "return", "text": "Easy 7-Day Returns" } }
      ]
    }
  ]
}
{% endschema %}
