{% render 'upaasak-design-system' %}

<section class="u-section u-trustbar" data-section-id="{{ section.id }}">
  <div class="u-trustbar__in">
    {% for block in section.blocks %}
      <div class="u-trustbar__item" {{ block.shopify_attributes }}>
        <span class="u-trustbar__icon">{% render 'upaasak-icon', icon: block.settings.icon %}</span>
        <div>
          <h4 class="u-trustbar__head">{{ block.settings.text }}</h4>
          {% if block.settings.subtext != blank %}<p class="u-trustbar__sub">{{ block.settings.subtext }}</p>{% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Trust Bar",
  "tag": "section",
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "certificate",
          "options": [
            { "value": "certificate", "label": "Certificate" }, { "value": "om", "label": "Om" },
            { "value": "leaf", "label": "Leaf" }, { "value": "shield", "label": "Shield" },
            { "value": "truck", "label": "Shipping" }, { "value": "return", "label": "Returns" },
            { "value": "lock", "label": "Secure" }, { "value": "headset", "label": "Support" }
          ]
        },
        { "type": "text", "id": "text", "label": "Heading", "default": "100% Original & Certified" },
        { "type": "text", "id": "subtext", "label": "Subtext" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upaasak Trust Bar",
      "blocks": [
        { "type": "usp", "settings": { "icon": "truck", "text": "Free Shipping", "subtext": "No minimum order value. Delivered Pan India." } },
        { "type": "usp", "settings": { "icon": "headset", "text": "Devotee Support", "subtext": "Reach us anytime via WhatsApp or Email." } },
        { "type": "usp", "settings": { "icon": "certificate", "text": "OSOC Certified", "subtext": "QR code on every product links to original lab report." } },
        { "type": "usp", "settings": { "icon": "om", "text": "Energized", "subtext": "Ready to wear. No activation needed." } }
      ]
    }
  ]
}
{% endschema %}
