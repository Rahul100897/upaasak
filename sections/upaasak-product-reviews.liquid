{% render 'upaasak-design-system' %}

<section class="u-section u-rev" data-section-id="{{ section.id }}">
  <div class="u-wrap">
    <div class="u-section-head is-centered">
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal>{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:80ms">{{ section.settings.heading }}</h2>
    </div>

    <div class="u-rev__summary" data-reveal>
      <div class="u-rev__score">
        <strong>{{ section.settings.avg_score }}</strong>
        <div class="u-rating" aria-label="rating">{% for i in (1..5) %}<svg viewBox="0 0 24 24"><path d="M12 2.5 14.8 9 22 9.6l-5.5 4.7L18.2 22 12 18l-6.2 4 1.7-7.7L2 9.6 9.2 9 12 2.5Z"/></svg>{% endfor %}</div>
        <span>{{ section.settings.review_count }} reviews</span>
      </div>
      <div class="u-rev__bars">
        {%- assign pcts = section.settings.distribution | split: ',' -%}
        {% for star in (1..5) %}
          {%- assign s = 5 | minus: forloop.index0 -%}
          {%- assign pct = pcts[forloop.index0] | default: '0' | strip -%}
          <div class="u-rev__bar">
            <span>{{ s }}★</span>
            <span class="u-rev__bar-track"><span class="u-rev__bar-fill" data-pct="{{ pct }}"></span></span>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="u-rev__grid">
      {% for block in section.blocks %}
        <article class="u-rev__card" data-reveal style="--d:{{ forloop.index0 | times: 70 }}ms" {{ block.shopify_attributes }}>
          <div class="u-rev__head">
            <div class="u-rev__who">
              <div class="u-rev__av">{{ block.settings.name | slice: 0 }}</div>
              <div>
                <div class="u-tml__name">{{ block.settings.name }}</div>
                <span class="u-verified">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9.5"/><path d="m8.5 12 2.4 2.4 4.6-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Verified Buyer
                </span>
              </div>
            </div>
          </div>
          <div class="u-rating">{% for i in (1..5) %}<svg viewBox="0 0 24 24"><path d="M12 2.5 14.8 9 22 9.6l-5.5 4.7L18.2 22 12 18l-6.2 4 1.7-7.7L2 9.6 9.2 9 12 2.5Z"/></svg>{% endfor %}</div>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Product Reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verified Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Devotees Are Saying" },
    { "type": "text", "id": "avg_score", "label": "Average score", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "1,284" },
    { "type": "text", "id": "distribution", "label": "Distribution % (5★,4★,3★,2★,1★)", "default": "92,6,1,1,0", "info": "Comma-separated percentages, highest star first." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Ravi K." },
        { "type": "textarea", "id": "text", "label": "Review", "default": "Beautiful bead, clearly authentic. Came with the certificate and a lovely pouch. Wearing it daily now." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upaasak Product Reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Ravi K.", "text": "Beautiful bead, clearly authentic. Came with a certificate and a lovely pouch. Wearing it daily now." } },
        { "type": "review", "settings": { "name": "Sneha P.", "text": "I was nervous buying online but the quality exceeded my expectations. Feels genuinely energized." } },
        { "type": "review", "settings": { "name": "Arjun M.", "text": "Fast delivery, premium packaging and great customer support. Will be ordering the 5 Mukhi next." } }
      ]
    }
  ]
}
{% endschema %}
