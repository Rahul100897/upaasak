{% style %}
#shopify-section-{{ section.id }} {
    width: 100%;
    display: block;
}

.hero-banner {
  position: relative;
  min-height: {{ section.settings.banner_height }}px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background-color: #70433e;
  background-image: url('{{ section.settings.banner_image | image_url: width: 2000 }}');
  background-repeat: no-repeat;
  background-size: cover;
  background-position: left center;
  padding: 40px 20px;
}

.hero-banner::before {
  content: '';
  position: absolute;
  inset: 0;
      background: rgb(0 0 0 / 60%);
}

.hero-banner__content {
  position: relative;
  z-index: 1;
}

.hero-banner h1 {
  margin: 0;
  color: {{ section.settings.heading_color }};
}

/* Tablet */
@media screen and (max-width: 991px) {
  .hero-banner {
    min-height: 200px;
    background-position: center;
  }

  .hero-banner h1 {
    font-size: 32px;
  }
}

/* Mobile */
@media screen and (max-width: 767px) {
  .hero-banner {
    min-height: 160px;
    padding: 30px 15px;
  }

  .hero-banner h1 {
    font-size: 28px;
  }
}
{% endstyle %}

<div class="hero-banner">
  <div class="hero-banner__content">
    <h1>{{ section.settings.heading }}</h1>
  </div>
</div>

{% schema %}
{
  "name": "Page Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 240
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#70433e"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Page Banner"
    }
  ]
}
{% endschema %}