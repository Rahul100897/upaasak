{% render 'upaasak-design-system' %}

<section class="u-section u-sec u-sec--paper" data-section-id="{{ section.id }}">
  <div class="u-wrap" data-tabs>
    <div class="u-section-head is-centered">
      {% if section.settings.eyebrow != blank %}<span class="u-eyebrow is-centered" data-reveal>{{ section.settings.eyebrow }}</span>{% endif %}
      <h2 class="u-title" data-reveal style="--d:60ms">{{ section.settings.heading }}</h2>
    </div>

    <div class="u-pills u-pills--center" role="tablist">
      {% for block in section.blocks %}
        <button type="button" class="u-pill{% if forloop.first %} is-active{% endif %}" data-tab="{{ block.id }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</button>
      {% endfor %}
    </div>

    {% for block in section.blocks %}
      {%- liquid
        assign coll = block.settings.collection
        if coll == blank
          assign coll = section.settings.source_collection
        endif
        if coll == blank or coll.products.size == 0
          assign coll = collections.all
        endif
        assign tag = block.settings.tag | strip
        assign limit = section.settings.count

        comment
          Iterate coll.products directly (no array filters) so collections.all works
          on the storefront. Ordering follows the source collection's sort order;
          'randomize' shuffles client-side.
        endcomment
        assign pool = limit
        if section.settings.randomize
          assign pool = 40
        endif

        assign matches = 0
        for product in coll.products
          if tag == blank or product.tags contains tag
            assign matches = matches | plus: 1
          endif
        endfor

        assign va_url = coll.url | default: routes.all_products_collection_url
        if tag != blank
          assign va_url = tag | handleize | prepend: '/' | prepend: routes.all_products_collection_url
        endif
      -%}
      <div class="u-panel{% if forloop.first %} is-active{% endif %}" data-panel="{{ block.id }}">
        {% if matches > 0 %}
          <div class="u-scroller" data-scroller>
            <button type="button" class="u-scroller__arrow u-scroller__arrow--prev" data-scroll-prev aria-label="Previous">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
            </button>
            <div class="u-prow" data-scroll{% if section.settings.randomize %} data-shuffle="{{ limit }}"{% endif %}>
              {%- assign shown = 0 -%}
              {% for product in coll.products %}
                {% if tag == blank or product.tags contains tag %}
                  {% if shown < pool %}
                    {% render 'upaasak-product-card', product: product %}
                    {%- assign shown = shown | plus: 1 -%}
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
            <button type="button" class="u-scroller__arrow u-scroller__arrow--next" data-scroll-next aria-label="Next">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          </div>
          {% if section.settings.show_view_all %}
            <div class="u-viewall">
              <a href="{{ va_url }}" class="u-btn u-btn--ghost">{{ section.settings.view_all_label }}</a>
            </div>
          {% endif %}
        {% else %}
          <p style="text-align:center;color:var(--u-muted);padding:30px 0">No products found for “{{ block.settings.label }}”. Set a matching tag (or leave empty for All) in the theme editor.</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Upaasak Shop by Purpose",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Find Your Path" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Purpose" },
    { "type": "collection", "id": "source_collection", "label": "Default products collection", "info": "Base source for the All tab and all tag filters. Pick a collection that contains all products (e.g. Shop All). Falls back to all products." },
    { "type": "range", "id": "count", "min": 2, "max": 10, "step": 1, "label": "Max products per filter", "default": 10 },
    { "type": "checkbox", "id": "randomize", "label": "Show random products", "info": "On = random selection each load. Off = follows the source collection's sort order (set it to 'Newest' for latest first).", "default": false },
    { "type": "checkbox", "id": "show_view_all", "label": "Show View All button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All" }
  ],
  "blocks": [
    {
      "type": "purpose",
      "name": "Purpose filter",
      "settings": [
        { "type": "text", "id": "label", "label": "Filter label", "default": "All" },
        { "type": "text", "id": "tag", "label": "Filter by tag", "info": "Shows products with this tag (e.g. Protection, Lord Murugan). Leave empty to show ALL products." },
        { "type": "collection", "id": "collection", "label": "Product source collection", "info": "Optional. Defaults to all products. Tag filter is applied within this." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upaasak Shop by Purpose",
      "blocks": [
        { "type": "purpose", "settings": { "label": "All" } },
        { "type": "purpose", "settings": { "label": "Protection", "tag": "Protection" } },
        { "type": "purpose", "settings": { "label": "Prosperity", "tag": "Prosperity" } },
        { "type": "purpose", "settings": { "label": "Healing", "tag": "Healing" } },
        { "type": "purpose", "settings": { "label": "Gifting", "tag": "Gifting" } }
      ]
    }
  ]
}
{% endschema %}
