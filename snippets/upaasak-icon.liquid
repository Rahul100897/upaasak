  {%- when 'shield' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5 4.5 5.5v6c0 4.6 3.2 8.2 7.5 10 4.3-1.8 7.5-5.4 7.5-10v-6L12 2.5Z"/><path d="m9 12 2 2 4-4.5"/></svg>
  {%- when 'leaf' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20c0-8 6-14 16-14 0 10-6 16-14 16-2 0-2-2-2-2Z"/><path d="M9 15c2.5-3 5-4.5 8-5.5"/></svg>
