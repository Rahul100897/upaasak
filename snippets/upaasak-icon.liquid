{%- comment -%}
  Upaasak icon library. Usage: {% render 'upaasak-icon', icon: 'lotus' %}
  All icons inherit currentColor; mix of stroke + fill line icons.
{%- endcomment -%}
{%- case icon -%}
  {%- when 'certificate' -%}
