  {%- when 'yatra' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5 13.8 6h-3.6L12 2.5Z"/><path d="M12 6v2"/><path d="M8.5 9.5h7L17 12H7l1.5-2.5Z"/><path d="M6.5 12h11v9h-11z"/><path d="M10.2 21v-3.2a1.8 1.8 0 0 1 3.6 0V21"/><path d="M4 21h16"/></svg>
  {%- when 'pooja' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 13.8c2 2.2 5 3.4 8.5 3.4s6.5-1.2 8.5-3.4c-2.6-1-5.5-1.6-8.5-1.6s-5.9.6-8.5 1.6Z"/><path d="M12 12.2V9.6"/><path d="M12 9.6c-1.5-1.3-1.5-3.3 0-4.8 1.5 1.5 1.5 3.5 0 4.8Z"/></svg>
