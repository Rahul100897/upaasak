  {%- when 'om' -%}
    <svg viewBox="0 0 24 24" fill="currentColor"><text x="12" y="19" text-anchor="middle" font-size="20" font-family="Marcellus, serif">ॐ</text></svg>
  {%- when 'truck' -%}
