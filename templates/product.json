    "u_sig": {
      "type": "upaasak-product-significance",
      "settings": {
        "eyebrow": "Spiritual Significance",
        "heading": "The Sacred Meaning of This Bead",
        "body": "<p>Each Mukhi (face) of a Rudraksha carries its own ruling deity, planet and blessing. Worn close to the skin, it is believed to balance the chakras, steady the mind and invite the grace it represents into your life.</p>",
        "mantra_label": "Beej Mantra",
        "mantra": "॥ ओं नमः शिवाय ॥"
      },
      "blocks": {
        "b1": {
          "type": "fact",
          "settings": {
            "label": "Ruling Deity",
            "value": "Lord Shiva"
          }
        },
        "b2": {
          "type": "fact",
          "settings": {
            "label": "Ruling Planet",
            "value": "Jupiter"
          }
        },
        "b3": {
          "type": "fact",
          "settings": {
            "label": "Chakra",
            "value": "Vishuddhi"
          }
        },
        "b4": {
          "type": "fact",
          "settings": {
            "label": "Origin",
            "value": "Nepal"
          }
        }
      },
      "block_order": [
        "b1",
        "b2",
        "b3",
        "b4"
      ]
    },
    "u_care": {
      "type": "upaasak-product-care",
      "settings": {
        "eyebrow": "Rituals",
        "heading": "How to Wear & Care for Your Mala",
        "subheading": "A few simple practices to keep your Rudraksha potent, beautiful and blessed for years."
      },
      "blocks": {
        "b1": {
          "type": "tip",
          "settings": {
            "icon": "water",
            "title": "Activate It",
            "text": "On a Monday morning, rinse with clean water or Ganga jal and chant the beej mantra 9 times before first wear."
          }
        },
        "b2": {
          "type": "tip",
          "settings": {
            "icon": "hand",
            "title": "Wear It Right",
            "text": "Wear against the skin or use for japa with your right hand, crossing the Sumeru (head) bead — never over it."
          }
        },
        "b3": {
          "type": "tip",
          "settings": {
            "icon": "leaf",
            "title": "Keep It Pure",
            "text": "Avoid harsh chemicals, perfumes and excess moisture. Remove before bathing or sleeping."
          }
        },
        "b4": {
          "type": "tip",
          "settings": {
            "icon": "sun",
            "title": "Recharge It",
            "text": "Oil the beads with sandalwood or mustard oil occasionally and let them rest in sunlight to retain lustre."
          }
        }
      },
      "block_order": [
        "b1",
        "b2",
        "b3",
        "b4"
      ]
    },
